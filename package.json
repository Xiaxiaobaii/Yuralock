{
  "name": "yuralock_tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "setup:win-cross": "./scripts/setup-win-cross.sh",
    "tauri:build": "vue-tsc --noEmit && tauri build && tauri build --target x86_64-pc-windows-gnu --no-bundle && npm run tauri build -- --runner cargo-xwin --target x86_64-pc-windows-gnu",
    "tauri:build:win-exe": "tauri build --target x86_64-pc-windows-gnu --no-bundle",
    "tauri:build:win-nsis": "tauri build --target x86_64-pc-windows-gnu --bundles nsis",
    "tauri:build:win-msi": "tauri build --target x86_64-pc-windows-gnu --bundles msi"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10",
    "@tauri-apps/cli": "^2"
  }
}
